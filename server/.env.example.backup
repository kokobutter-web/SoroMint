# Backup Service Environment Variables
# Copy this to .env and configure your values

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BACKUP_BUCKET=your-bucket-name

# Backup Encryption
# IMPORTANT: Store this password securely - backups cannot be restored without it!
# If not set, a random password will be generated (but you must save it!)
BACKUP_ENCRYPTION_PASSWORD=your-secure-encryption-password

# Backup Schedule (cron syntax)
# Default: daily at 02:00 UTC
BACKUP_CRON_SCHEDULE=0 2 * * *

# Recovery Test Schedule (cron syntax)
# Default: daily at 03:00 UTC (after backup)
RECOVERY_TEST_CRON_SCHEDULE=0 3 * * *

# Test MongoDB URI (optional - for recovery testing)
# Should point to a separate test database, not production
TEST_MONGO_URI=mongodb://localhost:27017/soromint_test